{
  "openapi": "3.1.0",
  "info": {
    "title": "Home Broker - Auth Service",
    "description": "Serviço responsável pela autenticação e gestão de usuários via Keycloak. Inclui fluxos de login, registro e renovação de tokens.",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8081/hb-auth-service",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "Autenticação",
      "description": "Endpoints para gestão de acesso, registro e renovação de tokens (Keycloak)"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Registrar novo investidor",
        "description": "Cria um novo usuário no Keycloak e sincroniza com a base local.",
        "operationId": "register",
        "parameters": [
          {
            "name": "X-API-KEY",
            "in": "header",
            "description": "Chave secreta para autorizar o registro",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Usuário criado com sucesso",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados de entrada inválidos",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "401": {
            "description": "X-API-KEY inválida ou ausente",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "422": {
            "description": "Conflito de dados (User/Email/TaxId já existem)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "502": {
            "description": "Erro de integração com o Keycloak",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Atualizar token (Refresh)",
        "description": "Gera um novo Access Token utilizando um Refresh Token válido",
        "operationId": "refresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Token atualizado com sucesso",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados de entrada inválidos (Bad Request)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Refresh Token expirado ou inválido",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "502": {
            "description": "Erro de integração com o Keycloak",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Realizar login",
        "description": "Autentica o usuário no Keycloak e retorna os tokens de acesso",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados de entrada inválidos (Bad Request)",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "502": {
            "description": "Erro de integração com o Keycloak",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "description": "Dados para criação de uma nova conta de investidor",
        "properties": {
          "username": {
            "type": "string",
            "description": "Nome de usuário único para acesso ao sistema",
            "example": "guilherme_eira"
          },
          "email": {
            "type": "string",
            "description": "Endereço de e-mail do investidor",
            "example": "guilherme@exemplo.com"
          },
          "taxId": {
            "type": "string",
            "description": "CPF ou CNPJ (somente números ou com máscara)",
            "example": "123.456.789-00"
          },
          "password": {
            "type": "string",
            "description": "Senha de acesso (deve seguir as políticas do Keycloak)",
            "example": "Senha@123",
            "pattern": "^(?=.*[0-9])(?=.*[a-z])(?=.*[A-Z])(?=.*[@#$%^&+=!])(?=\\S+$).{8,}$"
          },
          "firstName": {
            "type": "string",
            "description": "Primeiro nome do investidor",
            "example": "Guilherme"
          },
          "lastName": {
            "type": "string",
            "description": "Sobrenome do investidor",
            "example": "Eira"
          }
        },
        "required": [
          "email",
          "firstName",
          "lastName",
          "password",
          "taxId",
          "username"
        ]
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RefreshRequest": {
        "type": "object",
        "description": "Solicitação de renovação de token",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Token de renovação (refresh_token) recebido no login",
            "example": "eyJhbGciOiJIUzI1..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "tokenType": {
            "type": "string"
          },
          "expiresIn": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "description": "Dados necessários para autenticação do usuário",
        "properties": {
          "username": {
            "type": "string",
            "description": "Nome de usuário cadastrado",
            "example": "guilherme_invest"
          },
          "password": {
            "type": "string",
            "description": "Senha de acesso",
            "example": "Senha@123"
          }
        },
        "required": [
          "password",
          "username"
        ]
      }
    }
  }
}